APP_ENV=development
DATA_MODE=mock
MCP_ENABLED=true
# Use * for every company in the local company master, or a comma-separated allowlist.
ALLOWED_CO_CODES=*
COMPANY_INDEX_TTL_SECONDS=300

SQLITE_PATH=data/local/financial.sqlite3
SQLITE_READ_ONLY=true

# Optional multi-database registry. Missing file means no external SQL sources.
EXTERNAL_DATABASE_CONFIG_PATH=config/external_databases.local.json
EXTERNAL_DATABASE_STRICT=false
# TEMP_FINANCE_DATABASE_URL=postgresql+psycopg://readonly_user:password@host/database

# Optional approved read-only JSON REST providers.
EXTERNAL_API_CONFIG_PATH=config/external_apis.local.json
EXTERNAL_API_STRICT=false
# VENDOR_FINANCE_API_KEY=replace-me

NEO4J_URI=neo4j://127.0.0.1:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=replace-me
NEO4J_DATABASE=neo4j
NEO4J_VECTOR_INDEX=chunk_embedding_v1
NEO4J_FULLTEXT_INDEX=chunk_fulltext_v1
DOCUMENT_MIN_RELEVANCE_SCORE=0.60
GRAPH_MIN_RELEVANCE_SCORE=0.70
MAX_EVIDENCE_ITEMS=8
FINANCIAL_FACT_QUERY_LIMIT=2000
REQUIRE_DOCUMENT_PROVENANCE=true
HYBRID_VECTOR_WEIGHT=0.75

OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_EMBEDDING_MODEL=qwen3-embedding:0.6b

SEC_USER_AGENT=fin-poc/0.1 contact@example.com

COMPANY_LLM_MODE=mock
COMPANY_LLM_BASE_URL=https://your-company-api.example/v1
COMPANY_LLM_API_KEY=
COMPANY_LLM_MODEL=your-model
COMPANY_LLM_TIMEOUT_SECONDS=30
COMPANY_LLM_MAX_CONCURRENCY=16
COMPANY_LLM_MAX_CONNECTIONS=32
COMPANY_LLM_QUEUE_TIMEOUT_SECONDS=5
EMBEDDING_MAX_CONCURRENCY=8
API_MAX_CONCURRENCY=64
API_QUEUE_TIMEOUT_SECONDS=2
API_WORKERS=1

KNOWLEDGE_MCP_URL=http://127.0.0.1:8001/mcp
FINANCE_MCP_URL=http://127.0.0.1:8002/mcp
MCP_SHARED_TOKEN=replace-me
# none for local development; static for private server deployments.
MCP_AUTH_MODE=none
MCP_SERVER_HOST=127.0.0.1
MCP_BIND_HOST=127.0.0.1
API_HOST=127.0.0.1
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
KNOWLEDGE_MCP_PORT=8001
FINANCE_MCP_PORT=8002
RAG_MCP_PORT=8003
TRANSCRIPT_MCP_PORT=8004
FRONTEND_USE_PUBLIC_MCP=true
